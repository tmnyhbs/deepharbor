INSERT INTO member_to_role (role_id, member_id) VALUES (1, 3);   /* Nikola Tesla -> Authorizer */
INSERT INTO member_to_role (role_id, member_id) VALUES (1, 4);   /* Hedy Lamarr -> Authorizer */
