#
# docker build -t dhservice:latest .
#

FROM python:3.14-slim

# Install uv.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Install system dependencies.
# Curl is needed for health checks.
RUN apt-get update && apt-get install -y curl

# Copy the application into the container.
COPY . /app

# Install the application dependencies.
WORKDIR /app

ARG GIT_VERSION=unknown

RUN awk -v ver="$GIT_VERSION" 'BEGIN{ingit=0} /^\[git\]$/{ingit=1} /^\[/{if($0!="[git]") ingit=0} ingit && /^version=/{sub(/^version=.*/, "version=" ver)} {print}' config.ini > config.ini.tmp \
  && mv config.ini.tmp config.ini

RUN uv sync --frozen --no-cache

# Set Flask environment variables
ENV FLASK_APP=app.py

EXPOSE 5001

# Run the application using waitress WSGI server
# --trusted-proxy '*' tells waitress to trust proxy headers from any source
# --trusted-proxy-headers 'x-forwarded-for x-forwarded-host x-forwarded-proto x-forwarded-port' tells waitress which headers to trust
CMD ["/app/.venv/bin/python", "-m", "waitress", "--host=0.0.0.0", "--port=5001", "--trusted-proxy=*", "--trusted-proxy-headers=x-forwarded-for x-forwarded-host x-forwarded-proto x-forwarded-port", "--log-untrusted-proxy-headers", "app:app"]