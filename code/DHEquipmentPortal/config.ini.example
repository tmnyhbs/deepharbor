[flask]
secret_key=change-me-in-production

[dh_services]
; DHService API (member management) — accessed via gateway
api_base_url=http://localhost/dh/service
client_name=dev-equipment-portal
client_secret=secret

[dh_equipment]
; DHEquipment API — accessed via gateway
api_base_url=http://localhost/dh/equipment
client_name=dev-equipment-portal
client_secret=secret

[b2c]
; Azure AD B2C configuration — not needed in dev mode
TENANT_NAME=your-tenant
SIGNUPSIGNIN_USER_FLOW=B2C_1_signupsignin
EDITPROFILE_USER_FLOW=B2C_1_profileediting
RESETPASSWORD_USER_FLOW=B2C_1_passwordreset
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
ENDPOINT=your-api-endpoint

[git]
version=dev
